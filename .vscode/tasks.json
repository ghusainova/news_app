{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Runner",
            "type": "shell",
            "command": "./scripts/build_runner.sh"
        },
        {
            "label": "Watch Runner",
            "type": "shell",
            "command": "./scripts/watch_runner.sh"
        },
        {
            "label": "Clear Linter Errors",
            "type": "shell",
            "command": "dart fix --apply"
        },
        {
            "label": "Analyze Code",
            "type": "shell",
            "command": "flutter analyze"
        },
        {
            "label": "Mason activate",
            "type": "shell",
            "command": "dart pub global activate mason_cli"
        }
    ]
}